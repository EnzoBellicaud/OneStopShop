DJANGO_SECRET_KEY=dev-only-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
API_PORT=8000

POSTGRES_DB=oss_db
POSTGRES_USER=oss_user
POSTGRES_PASSWORD=oss_password
# Use localhost for local runs, and postgres when running inside docker compose.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SCHEMA=content

SCRAPER_TIMEOUT_SECONDS=30
CRAWLER_INTERVAL_SECONDS=1
SCRAPER_INTERVAL_SECONDS=1
SCRAPER_RUN_ON_START=true
SCRAPER_LLM_FALLBACK_THRESHOLD=0.60
SCRAPER_USER_AGENT=SUNRISE-OSS-Scraper/1.0
INGESTION_BOT_USERNAME=ingestion_bot

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud
OLLAMA_TIMEOUT_SECONDS=45
